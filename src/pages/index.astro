---
import Layout from '../layouts/Layout.astro'

const GITHUB = 'https://github.com/IldySilva/xell'
const RELEASES = `${GITHUB}/releases`
const MACOS_DMG = `${GITHUB}/releases/latest/download/xell-macos.dmg`
const LINUX_X64 = `${GITHUB}/releases/latest/download/xell-linux-x64.tar.gz`
const INSTALL_CMD = 'curl -fsSL https://raw.githubusercontent.com/IldySilva/xell/main/install.sh | bash'

const features = [
  {
    title: 'SSH host management',
    desc: 'Organize hosts locally. Tags, favorites, recent.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
  },
  {
    title: 'Integrated terminal',
    desc: 'Full xterm. ANSI, resize, zero lag.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
  },
  {
    title: 'SFTP browser',
    desc: 'Browse, upload, download, rename, delete.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    title: 'Port forwarding',
    desc: 'Tunnel remote ports to localhost.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`,
  },
  {
    title: 'Command palette',
    desc: '⌘K to connect, search, or jump anywhere.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  },
  {
    title: 'Secure credentials',
    desc: 'System keychain. Never plaintext.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
  },
]
---

<Layout>
  <!-- Nav -->
  <header class="fixed top-0 inset-x-0 z-50 border-b border-border/50 bg-bg/90 backdrop-blur-sm">
    <div class="max-w-4xl mx-auto px-6 h-13 flex items-center justify-between">
      <span class="font-mono text-[14px] text-text">xell</span>
      <div class="flex items-center gap-4">
        <a href={GITHUB} target="_blank" rel="noopener" class="text-muted hover:text-text transition-colors" aria-label="GitHub">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
        <a href={RELEASES} target="_blank" rel="noopener" class="px-3 py-1.5 rounded-md bg-accent text-white text-[13px] font-medium hover:bg-accent/90 transition-colors">Download</a>
      </div>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-6">

    <!-- Hero -->
    <section class="pt-40 pb-16">
      <div class="flex items-center gap-2 mb-6">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-surface border border-border text-[11px] font-mono text-muted">
          <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block"></span>
          latest release
        </span>
        <a href={RELEASES} target="_blank" rel="noopener" class="text-[11px] text-muted/60 hover:text-muted transition-colors">See changelog →</a>
      </div>

      <h1 class="text-4xl sm:text-5xl font-semibold text-text leading-[1.1] tracking-tight max-w-lg">
        Your servers.<br />One workspace.
      </h1>
      <p class="mt-5 text-[16px] text-muted leading-relaxed max-w-sm">
        Open-source SSH client for developers and DevOps engineers.
        Fast, focused, built to stay out of your way.
      </p>

      <!-- Download buttons -->
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={MACOS_DMG}
          class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-accent text-white text-[13px] font-medium hover:bg-accent/90 transition-colors"
        >
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/>
          </svg>
          Download for macOS
        </a>
        <a
          href={LINUX_X64}
          class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-surface border border-border text-[13px] text-text hover:border-accent/40 hover:text-text transition-colors"
        >
          <svg class="w-4 h-4 fill-current text-muted" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.354 1.611-.04 2.4.372.979 1.059 1.568 1.8 1.943.382.188.764.33 1.143.429 1.801.525 3.301-.375 4.194-1.502.265-.3.434-.602.434-.968 0-.547-.31-.867-.644-1.043-.354-.184-.764-.193-1.144-.062-.382.13-.745.4-.94.833-.15.338-.2.752-.088 1.119.104.344.335.63.678.795.232.116.494.143.745.08a1.47 1.47 0 0 0 .63-.357c.232-.215.38-.498.38-.807 0-.47-.3-.786-.6-.973-.305-.187-.65-.225-.993-.125l.007-.004c.48-.13 1.003-.072 1.43.222.425.294.696.788.696 1.374 0 .56-.262 1.057-.68 1.4-.417.345-.97.548-1.573.548-.602 0-1.154-.203-1.572-.548-.418-.343-.68-.84-.68-1.4 0-.585.271-1.079.696-1.373.425-.294.948-.354 1.43-.222l.006.003c-.341-.1-.685-.063-.99.125-.3.187-.6.503-.6.973 0 .31.148.592.38.807.23.215.503.34.63.357.25.063.512.036.744-.08.343-.165.574-.45.678-.795.112-.367.063-.78-.088-1.119-.195-.432-.558-.702-.94-.833-.38-.13-.79-.122-1.144.062-.334.176-.644.496-.644 1.043 0 .366.17.667.434.968.893 1.003 2.393 2.027 4.194 1.502.379-.1.761-.24 1.143-.429.741-.375 1.428-.964 1.8-1.943.314-.789.238-1.568-.04-2.4-.589-1.771-1.831-3.47-2.716-4.521-.75-1.067-.974-1.928-1.05-3.02-.065-1.491 1.056-5.965-3.17-6.298-.165-.013-.325-.021-.48-.021zm0 .948c.154 0 .309.008.463.02 3.564.282 2.724 4.265 2.79 5.783.062 1.394.376 2.453 1.26 3.675.794 1.143 2.016 2.61 2.677 4.396.263.786.306 1.375.065 1.97-.26.634-.754 1.04-1.353 1.366-.38.193-.751.327-1.115.42-1.607.468-2.922-.947-3.703-1.766-.28-.316-.39-.576-.39-.784 0-.358.19-.553.42-.673.23-.122.5-.145.75-.062.25.083.477.268.624.546.103.2.12.44.056.653-.063.208-.2.378-.388.466-.134.065-.28.082-.42.048a.838.838 0 0 1-.367-.208c-.13-.12-.213-.282-.213-.463 0-.272.176-.454.348-.558.175-.106.377-.13.574-.072l-.005-.002c-.26-.07-.527-.04-.757.101-.232.142-.39.378-.39.605 0 .193.09.37.24.508.15.14.353.223.568.223.216 0 .42-.084.568-.223.15-.138.24-.315.24-.508 0-.227-.158-.463-.39-.605-.23-.141-.497-.17-.757-.101l-.004.002c.197-.059.4-.034.574.072.172.104.348.286.348.558 0 .181-.083.344-.213.463-.133.12-.304.193-.367.208-.14.034-.286.017-.42-.048-.188-.088-.325-.258-.388-.466-.064-.213-.047-.453.056-.653.147-.278.373-.463.624-.546.25-.083.52-.06.75.062.23.12.42.315.42.673 0 .208-.11.468-.39.784-.781.82-2.096 2.234-3.703 1.766-.364-.093-.735-.227-1.115-.42-.599-.326-1.093-.732-1.353-1.366-.241-.595-.198-1.184.065-1.97.661-1.786 1.883-3.253 2.677-4.396.884-1.222 1.198-2.281 1.26-3.675.066-1.518-.774-5.501 2.79-5.783.154-.012.309-.02.463-.02z"/>
          </svg>
          Download for Linux
        </a>
      </div>

      <!-- Install -->
      <div id="install" class="mt-6 flex flex-col sm:flex-row items-stretch gap-2 max-w-xl">
        <div class="flex items-center gap-2 bg-surface border border-border rounded-lg px-4 py-3 flex-1 min-w-0">
          <span class="text-accent font-mono text-[13px] shrink-0">$</span>
          <code class="font-mono text-[13px] text-text truncate">{INSTALL_CMD}</code>
        </div>
        <button
          id="copy-btn"
          data-cmd={INSTALL_CMD}
          class="flex items-center justify-center gap-2 px-4 py-3 rounded-lg border border-border bg-surface text-[13px] text-muted hover:text-text hover:border-accent/30 transition-colors cursor-pointer shrink-0"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
          <span id="copy-label">Copy</span>
        </button>
      </div>
      <p class="mt-2 text-[11.5px] text-muted/50">macOS and Linux — or <a href={RELEASES} target="_blank" rel="noopener" class="text-muted hover:text-text transition-colors underline underline-offset-2">browse all releases</a></p>
    </section>

    <!-- Features -->
    <section class="py-16 border-t border-border">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border border border-border rounded-lg overflow-hidden">
        {features.map((f) => (
          <div class="bg-surface px-5 py-5 hover:bg-elevated transition-colors duration-150">
            <div class="w-4.5 h-4.5 text-muted mb-3" set:html={f.icon} />
            <p class="text-[13.5px] font-medium text-text mb-1">{f.title}</p>
            <p class="text-[12.5px] text-muted leading-snug">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Open source -->
    <section class="py-16 border-t border-border">
      <h2 class="text-[22px] font-semibold text-text tracking-tight mb-3">Open source</h2>
      <p class="text-[14.5px] text-muted leading-relaxed max-w-md mb-6">
        No telemetry. No analytics. No hidden calls.
        Credentials go to your system keychain — nowhere else.
        Read the code, contribute, or fork it.
      </p>
      <a href={GITHUB} target="_blank" rel="noopener" class="text-[13px] text-accent hover:underline">
        View on GitHub →
      </a>
    </section>

    <!-- Platforms -->
    <section class="py-10 border-t border-border">
      <div class="flex flex-wrap gap-6 text-[12.5px] text-muted items-center">
        <!-- Apple / macOS -->
        <span class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/>
          </svg>
          macOS
        </span>
        <!-- Linux -->
        <span class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.354 1.611-.04 2.4.372.979 1.059 1.568 1.8 1.943.382.188.764.33 1.143.429 1.801.525 3.301-.375 4.194-1.502.265-.3.434-.602.434-.968 0-.547-.31-.867-.644-1.043-.354-.184-.764-.193-1.144-.062-.382.13-.745.4-.94.833-.15.338-.2.752-.088 1.119.104.344.335.63.678.795.232.116.494.143.745.08a1.47 1.47 0 0 0 .63-.357c.232-.215.38-.498.38-.807 0-.47-.3-.786-.6-.973-.305-.187-.65-.225-.993-.125l.007-.004c.48-.13 1.003-.072 1.43.222.425.294.696.788.696 1.374 0 .56-.262 1.057-.68 1.4-.417.345-.97.548-1.573.548-.602 0-1.154-.203-1.572-.548-.418-.343-.68-.84-.68-1.4 0-.585.271-1.079.696-1.373.425-.294.948-.354 1.43-.222l.006.003c-.341-.1-.685-.063-.99.125-.3.187-.6.503-.6.973 0 .31.148.592.38.807.23.215.503.34.63.357.25.063.512.036.744-.08.343-.165.574-.45.678-.795.112-.367.063-.78-.088-1.119-.195-.432-.558-.702-.94-.833-.38-.13-.79-.122-1.144.062-.334.176-.644.496-.644 1.043 0 .366.17.667.434.968.893 1.003 2.393 2.027 4.194 1.502.379-.1.761-.24 1.143-.429.741-.375 1.428-.964 1.8-1.943.314-.789.238-1.568-.04-2.4-.589-1.771-1.831-3.47-2.716-4.521-.75-1.067-.974-1.928-1.05-3.02-.065-1.491 1.056-5.965-3.17-6.298-.165-.013-.325-.021-.48-.021zm0 .948c.154 0 .309.008.463.02 3.564.282 2.724 4.265 2.79 5.783.062 1.394.376 2.453 1.26 3.675.794 1.143 2.016 2.61 2.677 4.396.263.786.306 1.375.065 1.97-.26.634-.754 1.04-1.353 1.366-.38.193-.751.327-1.115.42-1.607.468-2.922-.947-3.703-1.766-.28-.316-.39-.576-.39-.784 0-.358.19-.553.42-.673.23-.122.5-.145.75-.062.25.083.477.268.624.546.103.2.12.44.056.653-.063.208-.2.378-.388.466-.134.065-.28.082-.42.048a.838.838 0 0 1-.367-.208c-.13-.12-.213-.282-.213-.463 0-.272.176-.454.348-.558.175-.106.377-.13.574-.072l-.005-.002c-.26-.07-.527-.04-.757.101-.232.142-.39.378-.39.605 0 .193.09.37.24.508.15.14.353.223.568.223.216 0 .42-.084.568-.223.15-.138.24-.315.24-.508 0-.227-.158-.463-.39-.605-.23-.141-.497-.17-.757-.101l-.004.002c.197-.059.4-.034.574.072.172.104.348.286.348.558 0 .181-.083.344-.213.463-.133.12-.304.193-.367.208-.14.034-.286.017-.42-.048-.188-.088-.325-.258-.388-.466-.064-.213-.047-.453.056-.653.147-.278.373-.463.624-.546.25-.083.52-.06.75.062.23.12.42.315.42.673 0 .208-.11.468-.39.784-.781.82-2.096 2.234-3.703 1.766-.364-.093-.735-.227-1.115-.42-.599-.326-1.093-.732-1.353-1.366-.241-.595-.198-1.184.065-1.97.661-1.786 1.883-3.253 2.677-4.396.884-1.222 1.198-2.281 1.26-3.675.066-1.518-.774-5.501 2.79-5.783.154-.012.309-.02.463-.02z"/>
          </svg>
          Linux
        </span>
        <!-- iOS -->
        <span class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.4c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 3.99zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
          </svg>
          iOS
        </span>
        <!-- Android -->
        <span class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.523 15.3414c-.5511 0-.9993-.4486-.9993-.9997s.4482-.9993.9993-.9993c.5511 0 .9993.4482.9993.9993.0001.5511-.4482.9997-.9993.9997m-11.046 0c-.5511 0-.9993-.4486-.9993-.9997s.4482-.9993.9993-.9993c.5511 0 .9993.4482.9993.9993 0 .5511-.4482.9997-.9993.9997m11.4045-6.02l1.9973-3.4592a.416.416 0 0 0-.1521-.5676.416.416 0 0 0-.5676.1521l-2.0223 3.503C15.5902 8.2439 13.8533 7.8508 12 7.8508s-3.5902.3931-5.1367 1.0989L4.841 5.4467a.4161.4161 0 0 0-.5677-.1521.4157.4157 0 0 0-.1521.5676l1.9973 3.4592C2.6889 11.1867.3432 14.6589 0 18.761h24c-.3435-4.1021-2.6892-7.5743-6.1185-9.4396"/>
          </svg>
          Android
        </span>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="border-t border-border mt-8">
    <div class="max-w-4xl mx-auto px-6 py-6 flex items-center justify-between">
      <span class="font-mono text-[12px] text-muted/60">xell</span>
      <div class="flex gap-5 text-[12px] text-muted">
        <a href={GITHUB} target="_blank" rel="noopener" class="hover:text-text transition-colors flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
          GitHub
        </a>
        <a href={RELEASES} target="_blank" rel="noopener" class="hover:text-text transition-colors">Releases</a>
      </div>
    </div>
  </footer>
</Layout>

<script>
  const btn = document.getElementById('copy-btn') as HTMLButtonElement
  const label = document.getElementById('copy-label') as HTMLSpanElement

  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(btn.dataset.cmd ?? '')
    label.textContent = 'Copied!'
    setTimeout(() => { label.textContent = 'Copy' }, 2000)
  })
</script>
